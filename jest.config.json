{
    "verbose": true,
    "testEnvironment": "node",
    "moduleDirectories": ["node_modules", "src"],
    "moduleNameMapper": {
        "^@/(.*)$": "<rootDir>/src/$1",
        "^@services/(.*)$": "<rootDir>/src/Application/services/$1",
        "^@services$": "<rootDir>/src/Application/services",
        "^@repositories/(.*)$": "<rootDir>/src/Application/repositories/$1",
        "^@repositories$": "<rootDir>/src/Application/repositories",
        "^@models/(.*)$": "<rootDir>/src/Infrastructure/models/$1",
        "^@models$": "<rootDir>/src/Infrastructure/models",
        "^@embeds/(.*)$": "<rootDir>/src/Client/components/embeds/$1",
        "^@embeds$": "<rootDir>/src/Client/components/embeds",
        "^@buttons/(.*)$": "<rootDir>/src/Client/components/buttons/$1",
        "^@buttons$": "<rootDir>/src/Client/components/buttons",
        "^@modals/(.*)$": "<rootDir>/src/Client/components/modals/$1",
        "^@modals$": "<rootDir>/src/Client/components/modals",
        "^@commands/(.*)$": "<rootDir>/src/Client/commands/$1",
        "^@commands$": "<rootDir>/src/Client/commands",
        "^@events/(.*)$": "<rootDir>/src/Client/events/$1",
        "^@events$": "<rootDir>/src/Client/events",
        "^@jobs/(.*)$": "<rootDir>/src/Client/jobs/$1",
        "^@jobs$": "<rootDir>/src/Client/jobs",
        "^@utils/(.*)$": "<rootDir>/src/Client/utils/$1",
        "^@utils$": "<rootDir>/src/Client/utils",
        "^@config/(.*)$": "<rootDir>/src/config/$1",
        "^@config$": "<rootDir>/src/config",
        "^@api/(.*)$": "<rootDir>/src/Api/$1",
        "^@api$": "<rootDir>/src/Api",
        "^@root/(.*)$": "<rootDir>/src/$1",
        "^@root$": "<rootDir>/src"
    },
    "transform": {
        "^.+\\.js$": "babel-jest"
    },
    "roots": ["<rootDir>/src"],
    "testMatch": ["**/__tests__/**/*.js", "**/?(*.)+(spec|test).js"],
    "collectCoverage": true,
    "clearMocks": true,
    "resetMocks": true
}
